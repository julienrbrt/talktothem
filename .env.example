# TalkToThem Configuration

# Path to store database and conversation history
# Default: ~/.config/talktothem/
TALKTOTHEM_DATA_PATH=/path/to/data

# Signal CLI REST API URL
# Default: http://localhost:8080
# For Docker: http://signal-api:8080
SIGNAL_API_URL=http://localhost:8080

# go-whatsapp-web-multidevice API URL
# Default: http://localhost:3000
# For Docker: http://whatsapp-api:3000
WHATSAPP_API_URL=http://localhost:3000
